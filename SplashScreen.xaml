<Window x:Class="FileOrganizer.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Portable File Organizer" 
        Height="450" Width="650"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border CornerRadius="15" Background="White" BorderBrush="#0078D4" BorderThickness="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="8" Opacity="0.4" BlurRadius="20"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Main Content -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                <!-- Icon -->
                <Viewbox Width="140" Height="140" Margin="0,0,0,25">
                    <Grid Width="100" Height="100">
                        <Ellipse Fill="#0078D4" Width="100" Height="100"/>
                        <Path Data="M30,50 L45,35 L45,50 L55,50 L55,35 L70,50 L70,65 L30,65 Z" 
                              Fill="White" Stretch="Uniform" 
                              Width="50" Height="50"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>

                <!-- Title -->
                <TextBlock Text="Portable File Organizer" 
                          FontSize="42" 
                          FontWeight="Bold" 
                          Foreground="#0078D4" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,12"/>
                
                <!-- Version -->
                <TextBlock Text="v5.0 build 1.2.11" 
                          FontSize="20" 
                          Foreground="#666" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,8"/>
                
                <!-- Tagline -->
                <TextBlock Text="Professional File Management Solution" 
                          FontSize="16" 
                          Foreground="#999" 
                          HorizontalAlignment="Center" 
                          FontStyle="Italic" 
                          Margin="0,0,0,35"/>
            </StackPanel>

            <!-- Features -->
            <Border Grid.Row="1" Background="#F5F5F5" Padding="35,18">
                <WrapPanel HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                        <TextBlock Text="✓" FontSize="18" Foreground="#4CAF50" Margin="0,0,6,0" FontWeight="Bold"/>
                        <TextBlock Text="Smart Organization" FontSize="14" Foreground="#666"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                        <TextBlock Text="⚡" FontSize="18" Margin="0,0,6,0"/>
                        <TextBlock Text="Lightning Fast" FontSize="14" Foreground="#666"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔒" FontSize="18" Margin="0,0,6,0"/>
                        <TextBlock Text="Safe and Secure" FontSize="14" Foreground="#666"/>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- Loading Bar -->
            <Grid Grid.Row="2" Margin="60,25">
                <Border Height="6" Background="#E0E0E0" CornerRadius="3"/>
                <ProgressBar x:Name="LoadingProgress"
                            Value="0"
                            Maximum="100"
                            Height="6" 
                            Foreground="#0078D4" 
                            BorderThickness="0" 
                            Background="Transparent"/>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#0078D4" CornerRadius="0,0,11,11">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Loading your file organizer..." 
                             Foreground="White" 
                             FontSize="13" 
                             HorizontalAlignment="Center" 
                             Margin="0,0,0,4"/>
                    <TextBlock Text="© 2026 - All Rights Reserved" 
                             Foreground="#B3D9F2" 
                             FontSize="11" 
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
