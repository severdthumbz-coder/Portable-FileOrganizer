<Window x:Class="FileOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FileOrganizer"
        xmlns:vm="clr-namespace:FileOrganizer.ViewModels"
        xmlns:models="clr-namespace:FileOrganizer.Models"
        xmlns:controls="clr-namespace:FileOrganizer.Controls"
        xmlns:converters="clr-namespace:FileOrganizer.Converters"
        xmlns:views="clr-namespace:FileOrganizer.Views"
        Title="Portable File Organizer v5.0 build 1.4.2" 
        Height="900" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!--
        Converters were moved to App.xaml (application scope) so that the tab
        UserControls in Views/ can resolve them via StaticResource.
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                <Viewbox Width="60" Height="60" Margin="0,0,20,0">
                    <Path Data="M10,4H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8c0-1.1,0.9-2-2-2h-8L10,4z" 
                          Fill="White" Stretch="Uniform"/>
                </Viewbox>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Portable File Organizer v5.0 build 1.4.2" 
                              FontSize="32" 
                              FontWeight="Bold" 
                              Foreground="{DynamicResource HeaderTextBrush}"/>
                    <TextBlock Text="Organize your files automatically with Smart Categorization" 
                              FontSize="14" 
                              Foreground="{DynamicResource HeaderTextBrush}" 
                              Opacity="0.8"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                <Button x:Name="ThemeToggleButton" 
                       Width="40" Height="40" 
                       Background="Transparent" 
                       BorderThickness="0"
                       Click="ThemeToggleButton_Click"
                       Cursor="Hand"
                       ToolTip="Toggle Dark/Light Mode">
                    <Path x:Name="ThemeIcon"
                          Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95M17.33,17.97C14.5,17.81 11.7,16.64 9.53,14.5C7.36,12.31 6.2,9.5 6.04,6.68C3.23,9.82 3.34,14.64 6.35,17.66C9.37,20.67 14.19,20.78 17.33,17.97Z" 
                          Fill="White" 
                          Stretch="Uniform" 
                          Width="24" 
                          Height="24"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- TABS -->
        <TabControl Grid.Row="1" 
                   Background="{DynamicResource WindowBackgroundBrush}"
                   BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" 
                                       Background="{DynamicResource PanelBackgroundBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}"
                                       BorderThickness="0,0,1,2"
                                       Padding="20,12">
                                    <ContentPresenter x:Name="ContentSite"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>
            <!-- CONFIGURATION TAB - COMPLETELY REVISED TO MATCH v4.0 -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Configuration"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ConfigurationTabView/>
            </TabItem>

            <!-- OPERATIONS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Operations"/>
                    </StackPanel>
                </TabItem.Header>
                <views:OperationsTabView/>
            </TabItem>

            <!-- STATISTICS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Statistics"/>
                    </StackPanel>
                </TabItem.Header>
                <views:StatisticsTabView/>
            </TabItem>
            <!-- EXCEPTIONS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚫" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Exceptions"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ExceptionsTabView/>
            </TabItem>


            <!-- AUTOMATION TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Automation"/>
                    </StackPanel>
                </TabItem.Header>
                <views:AutomationTabView DataContext="{Binding Automation}"/>
            </TabItem>


            <!-- SEARCH TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔎" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Search"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SearchTabView DataContext="{Binding Search}"/>
            </TabItem>

            <!-- HISTORY TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="History"/>
                    </StackPanel>
                </TabItem.Header>
                <views:HistoryTabView/>
            </TabItem>

            <!-- DUPLICATES TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔁" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Duplicates"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DuplicatesTabView/>
            </TabItem>

            <!-- HELP TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❓" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Help"/>
                    </StackPanel>
                </TabItem.Header>
                <views:HelpTabView/>
            </TabItem>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" 
               Background="{DynamicResource PanelBackgroundBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               BorderThickness="0,1,0,0"
               Padding="20,10,20,0">
            <StackPanel>
                <!-- Status Text -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Status: " 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding StatusMessage}" 
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="13"
                                  FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="⏱ " 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding LastOperationDuration}" 
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="13"
                                  FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3" 
                              Text="{Binding VersionInfo}" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="12"/>
                </Grid>
                
                <!-- Progress Bar -->
                <ProgressBar Value="{Binding ProgressValue}" 
                            Minimum="0" 
                            Maximum="100"
                            Height="4"
                            Margin="0,0,0,10"
                            Background="{DynamicResource BorderBrush}"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <!-- Background Track -->
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="2"
                                                   Height="4"/>
                                            <!-- Foreground Indicator -->
                                            <Border Background="{TemplateBinding Foreground}"
                                                   CornerRadius="2"
                                                   Height="4"
                                                   HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <!-- Hide when progress is 0 -->
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProgressValue}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </StackPanel>
        </Border>
        
        <!-- Banner Notification (overlays on top) -->
        <controls:BannerNotification x:Name="CompletionBanner"
                                     Grid.RowSpan="3"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Stretch"
                                     Margin="0,10,0,0"
                                     Visibility="Collapsed"
                                     Panel.ZIndex="1000"/>
    </Grid>
</Window>
