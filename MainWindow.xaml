<Window x:Class="FileOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FileOrganizer"
        xmlns:vm="clr-namespace:FileOrganizer.ViewModels"
        xmlns:models="clr-namespace:FileOrganizer.Models"
        xmlns:controls="clr-namespace:FileOrganizer.Controls"
        xmlns:converters="clr-namespace:FileOrganizer.Converters"
        Title="Portable File Organizer v5.0 build 1.2.11" 
        Height="900" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:ExpandCollapseConverter x:Key="ExpandCollapseConverter"/>
        <local:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                <Viewbox Width="60" Height="60" Margin="0,0,20,0">
                    <Path Data="M10,4H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8c0-1.1,0.9-2-2-2h-8L10,4z" 
                          Fill="White" Stretch="Uniform"/>
                </Viewbox>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Portable File Organizer v5.0 build 1.2.11" 
                              FontSize="32" 
                              FontWeight="Bold" 
                              Foreground="{DynamicResource HeaderTextBrush}"/>
                    <TextBlock Text="Organize your files automatically with Smart Categorization" 
                              FontSize="14" 
                              Foreground="{DynamicResource HeaderTextBrush}" 
                              Opacity="0.8"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                <Button x:Name="ThemeToggleButton" 
                       Width="40" Height="40" 
                       Background="Transparent" 
                       BorderThickness="0"
                       Click="ThemeToggleButton_Click"
                       Cursor="Hand"
                       ToolTip="Toggle Dark/Light Mode">
                    <Path x:Name="ThemeIcon"
                          Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95M17.33,17.97C14.5,17.81 11.7,16.64 9.53,14.5C7.36,12.31 6.2,9.5 6.04,6.68C3.23,9.82 3.34,14.64 6.35,17.66C9.37,20.67 14.19,20.78 17.33,17.97Z" 
                          Fill="White" 
                          Stretch="Uniform" 
                          Width="24" 
                          Height="24"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- TABS -->
        <TabControl Grid.Row="1" 
                   Background="{DynamicResource WindowBackgroundBrush}"
                   BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" 
                                       Background="{DynamicResource PanelBackgroundBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}"
                                       BorderThickness="0,0,1,2"
                                       Padding="20,12">
                                    <ContentPresenter x:Name="ContentSite"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>
            <!-- CONFIGURATION TAB - COMPLETELY REVISED TO MATCH v4.0 -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Configuration"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        
                        <!-- Scan Mode Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="💻" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="System Detection" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding SystemDetectedDescription}" 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource AccentBrush}"
                                          FontSize="14"
                                          FontWeight="Medium"
                                          Margin="0,0,0,5"/>
                                
                                <TextBlock Text="Scan modes will automatically adapt to your system's capabilities." 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,0"
                                          LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <!-- Scan Mode Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="🔍" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Scan Mode" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <!-- System Detection Display -->
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}"
                                       BorderThickness="1"
                                       CornerRadius="3"
                                       Padding="12,8"
                                       Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💻" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="System Detected: " 
                                                  FontSize="13" 
                                                  Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SystemDetectedDescription}" 
                                                  FontSize="13" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Manual Storage Override -->
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                       BorderBrush="{DynamicResource AccentBrush}"
                                       BorderThickness="2"
                                       CornerRadius="5"
                                       Padding="15"
                                       Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="🎯" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="Drive Type Override" 
                                                      FontSize="15" 
                                                      FontWeight="SemiBold" 
                                                      Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>

                                        <TextBlock Text="If auto-detection fails, manually specify your drive type for optimal performance:" 
                                                  TextWrapping="Wrap"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="12"
                                                  Margin="0,0,0,12"/>

                                        <RadioButton Content="Auto-detect (use WMI detection)" 
                                                    GroupName="StorageOverride"
                                                    IsChecked="{Binding StorageOverrideAuto}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    FontSize="13"
                                                    Margin="0,0,0,8"/>

                                        <RadioButton Content="Force NVMe (32 threads max - fastest for NVMe SSDs)" 
                                                    GroupName="StorageOverride"
                                                    IsChecked="{Binding StorageOverrideNVMe}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Margin="0,0,0,8"/>

                                        <RadioButton Content="Force SSD (16 threads max - for SATA SSDs)" 
                                                    GroupName="StorageOverride"
                                                    IsChecked="{Binding StorageOverrideSSD}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    FontSize="13"
                                                    Margin="0,0,0,8"/>

                                        <RadioButton Content="Force HDD (4 threads max - for rotational drives)" 
                                                    GroupName="StorageOverride"
                                                    IsChecked="{Binding StorageOverrideHDD}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    FontSize="13"
                                                    Margin="0,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Select Mode:" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                    <ComboBox Grid.Column="1" 
                                             ItemsSource="{Binding ScanModes}"
                                             SelectedValue="{Binding SelectedScanMode}"
                                             DisplayMemberPath="Display"
                                             SelectedValuePath="Value"
                                             Height="35"
                                             FontSize="14"
                                             Margin="0,5"/>
                                </Grid>

                                <TextBlock Text="{Binding ScanModeDescription}" 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          Margin="0,10,0,0"
                                          LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Copy/Move Engine Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="🚀" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Copy/Move Engine" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Select Engine:" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                    <ComboBox Grid.Column="1" 
                                             ItemsSource="{Binding CopyEngines}"
                                             SelectedValue="{Binding SelectedCopyEngine}"
                                             DisplayMemberPath="Display"
                                             SelectedValuePath="Value"
                                             Height="35"
                                             FontSize="14"
                                             Margin="0,5"/>
                                </Grid>

                                <TextBlock Text="{Binding CopyEngineDescription}" 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          Margin="0,10,0,0"
                                          LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Engine Detection Status Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20"
                               Visibility="{Binding ShowEngineDetection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="🔧" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Engine Detection Status" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                              Text="{Binding SelectedEngineLabel}"
                                              FontSize="14"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                              Text="Status:"
                                              FontSize="14"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="2" 
                                              Text="{Binding EngineDetectionStatus}"
                                              FontSize="14"
                                              Foreground="{Binding EngineStatusColor}"
                                              FontWeight="SemiBold"
                                              VerticalAlignment="Center"/>

                                    <Button Grid.Column="4"
                                           Content="🔍 Detect"
                                           Command="{Binding DetectEngineCommand}"
                                           Padding="15,8"
                                           Background="{DynamicResource AccentBrush}"
                                           Foreground="White"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Operation Mode Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Operation Mode" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <RadioButton Content="Move Files" 
                                                IsChecked="{Binding OperationMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:FileOperationMode.Move}}"
                                                Margin="0,0,30,0"
                                                FontSize="14"/>
                                    <RadioButton Content="Copy Files"
                                                IsChecked="{Binding OperationMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:FileOperationMode.Copy}}"
                                                FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="• Move: Transfers files to destination and removes from source" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,2"/>
                                    <TextBlock Text="• Copy: Duplicates files to destination, keeps originals in source" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,2"/>
                                </StackPanel>

                                <!-- Timestamp Preservation Option -->
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                       BorderBrush="{DynamicResource AccentBrush}"
                                       BorderThickness="1"
                                       CornerRadius="3"
                                       Padding="15,10"
                                       Margin="0,15,0,0">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding PreserveTimestamps}"
                                                 FontSize="14"
                                                 FontWeight="SemiBold"
                                                 Foreground="{DynamicResource TextBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅 " FontSize="14"/>
                                                <TextBlock Text="Preserve File Timestamps" FontSize="14"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <TextBlock Text="When enabled, maintains original creation date, modification date, and file attributes" 
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="12"
                                                  Margin="20,5,0,0"
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Data Integrity Verification Option -->
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                       BorderBrush="{DynamicResource AccentBrush}"
                                       BorderThickness="1"
                                       CornerRadius="3"
                                       Padding="15,10"
                                       Margin="0,10,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="🔒 " FontSize="14"/>
                                            <TextBlock Text="Data Integrity Verification" 
                                                      FontSize="14" 
                                                      FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>

                                        <ComboBox SelectedItem="{Binding VerificationMode}"
                                                 ItemsSource="{Binding VerificationModes}"
                                                 FontSize="13"
                                                 Padding="10,8"
                                                 Margin="0,0,0,10">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding}" Value="None">
                                                                        <Setter Property="Text" Value="None - No verification (fastest, not recommended)"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding}" Value="SizeOnly">
                                                                        <Setter Property="Text" Value="Size Only - Quick size check (fast)"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding}" Value="Smart">
                                                                        <Setter Property="Text" Value="Smart - Hash small files (recommended)"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding}" Value="FullHash">
                                                                        <Setter Property="Text" Value="Full Hash - Verify all files (safest)"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!-- Dynamic Description based on selected mode -->
                                        <StackPanel Margin="0,5,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <!-- None Mode -->
                                                        <DataTrigger Binding="{Binding VerificationMode}" Value="None">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="⚠️ WARNING: Files are not verified after copy/move" 
                                                      Foreground="#FF6B6B"
                                                      FontSize="12"
                                                      Margin="0,0,0,3"
                                                      TextWrapping="Wrap"
                                                      FontWeight="SemiBold"/>
                                            <TextBlock Text="• Fastest performance - no verification overhead" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Risk: Silent data corruption possible" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Not recommended for important files" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,5,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VerificationMode}" Value="SizeOnly">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="• Compares file sizes after copy/move (instant check)" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Catches 95% of copy failures (incomplete files, disk full errors)" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Performance impact: None (instant verification)" 
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      FontWeight="SemiBold"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Good for large video files where hash would be slow" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,5,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VerificationMode}" Value="Smart">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="✅ RECOMMENDED - Best balance of speed and safety" 
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      FontSize="12"
                                                      Margin="0,0,0,3"
                                                      TextWrapping="Wrap"
                                                      FontWeight="SemiBold"/>
                                            <TextBlock Text="• Files under 10MB: Full SHA256 hash verification (photos, documents)" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Files over 10MB: Quick size check only (videos, large files)" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Performance impact: 5-10% slower overall" 
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      FontWeight="SemiBold"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Perfect for photo libraries and document organization" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,5,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VerificationMode}" Value="FullHash">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="• Full SHA256 hash verification for every file" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• 100% data integrity guarantee - catches all corruption" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Performance impact: ~50-100% slower (doubles operation time)" 
                                                      Foreground="#FF6B6B"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      FontWeight="SemiBold"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="• Use for critical data, legal documents, or maximum safety" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="0,2"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <TextBlock Text="Failed operations will automatically retry based on Error Recovery settings below" 
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="11"
                                                  Margin="0,10,0,0"
                                                  FontStyle="Italic"
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Destination Folder Structure Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="📁" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Destination Folder Structure" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <StackPanel>
                                    <RadioButton Content="Organize by Category" 
                                                IsChecked="{Binding StructureMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:DestinationStructureMode.OrganizeByCategory}}"
                                                Margin="0,5"
                                                FontSize="14"/>
                                    <RadioButton Content="Preserve Structure (Recommended)"
                                                IsChecked="{Binding StructureMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:DestinationStructureMode.PreserveStructure}}"
                                                Margin="0,5"
                                                FontSize="14"/>
                                    <RadioButton Content="Hybrid"
                                                IsChecked="{Binding StructureMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:DestinationStructureMode.Hybrid}}"
                                                Margin="0,5"
                                                FontSize="14"/>
                                </StackPanel>

                                <TextBlock Text="{Binding StructureModeDescription}" 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          Margin="0,10,0,0"
                                          LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- File Conflict Resolution -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="⚠" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="File Conflict Resolution" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="If file exists:" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                    <ComboBox Grid.Column="1" 
                                             ItemsSource="{Binding ConflictResolutions}"
                                             SelectedValue="{Binding ConflictResolution}"
                                             DisplayMemberPath="Display"
                                             SelectedValuePath="Value"
                                             Height="35"
                                             FontSize="14"
                                             Margin="0,5"/>
                                </Grid>
                                
                                <!-- Description of selected option -->
                                <TextBlock Text="{Binding ConflictResolutionDescription}"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          TextWrapping="Wrap"
                                          Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Source Folders Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="📂" FontSize="18" Margin="0,0,10,0"/>
                                        <TextBlock Text="Source Folders" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                             Content="Use Multiple Sources"
                                             IsChecked="{Binding UseMultipleSources}"
                                             FontSize="13"
                                             VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Single Source Mode -->
                                <Grid Visibility="{Binding UseMultipleSources, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" 
                                            Text="{Binding SourceFolder}"
                                            Height="35"
                                            VerticalContentAlignment="Center"
                                            Padding="10,0"
                                            Margin="0,0,10,0"/>
                                    <Button Grid.Column="1"
                                           Content="Browse"
                                           Command="{Binding BrowseSourceCommand}"
                                           Padding="20,8"
                                           Background="{DynamicResource AccentBrush}"
                                           Foreground="White"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                </Grid>

                                <!-- Multiple Sources Mode -->
                                <StackPanel Visibility="{Binding UseMultipleSources, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGrid x:Name="SourceFoldersDataGrid"
                                             ItemsSource="{Binding SourceFolders}"
                                             AutoGenerateColumns="False"
                                             SelectionMode="Extended"
                                             Background="{DynamicResource WindowBackgroundBrush}"
                                             RowBackground="{DynamicResource PanelBackgroundBrush}"
                                             AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                             BorderThickness="1"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             GridLinesVisibility="Horizontal"
                                             HeadersVisibility="Column"
                                             Height="150"
                                             Margin="0,0,0,10">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Path" Binding="{Binding}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <WrapPanel>
                                        <Button Content="➕ Add Source"
                                               Command="{Binding AddSourceFolderCommand}"
                                               Padding="15,8"
                                               Margin="0,0,10,0"
                                               Background="{DynamicResource AccentBrush}"
                                               Foreground="White"
                                               BorderThickness="0"
                                               Cursor="Hand"/>
                                        <Button Content="➖ Remove Selected"
                                               Click="RemoveSelectedSourceFolders_Click"
                                               Padding="15,8"
                                               Background="{DynamicResource ErrorBrush}"
                                               Foreground="White"
                                               BorderThickness="0"
                                               Cursor="Hand"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Destination Folder Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="📁" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Destination Folder" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" 
                                            Text="{Binding DestinationFolder}"
                                            Height="35"
                                            VerticalContentAlignment="Center"
                                            Padding="10,0"
                                            Margin="0,0,10,0"/>
                                    <Button Grid.Column="1"
                                           Content="Browse"
                                           Command="{Binding BrowseDestinationCommand}"
                                           Padding="20,8"
                                           Background="{DynamicResource AccentBrush}"
                                           Foreground="White"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Space Analysis Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="💾" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Space Analysis" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <!-- Instructions (visible when analysis not completed) -->
                                <TextBlock Text="Click 'Analyze Space' to see available disk space and estimated file sizes." 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          Margin="0,0,0,15"
                                          Visibility="{Binding SpaceAnalysisCompleted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}"/>

                                <!-- Space Analysis Results (visible after analysis) -->
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}"
                                       BorderThickness="1"
                                       CornerRadius="3"
                                       Padding="15"
                                       Margin="0,0,0,15"
                                       Visibility="{Binding SpaceAnalysisCompleted, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="💾 Space Analysis Results:" 
                                                  FontWeight="SemiBold"
                                                  FontSize="13"
                                                  Foreground="{DynamicResource TextBrush}"
                                                  Margin="0,0,0,10"/>
                                        
                                        <!-- Source Files -->
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="Source Files: " 
                                                      Foreground="{DynamicResource TextSecondaryBrush}" 
                                                      FontSize="13"/>
                                            <TextBlock Text="{Binding SpaceAnalysisSourceFiles}" 
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="13"/>
                                        </StackPanel>
                                        
                                        <!-- Destination Free Space -->
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="💿" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="Destination Free Space: " 
                                                      Foreground="{DynamicResource TextSecondaryBrush}" 
                                                      FontSize="13"/>
                                            <TextBlock Text="{Binding SpaceAnalysisDestFreeSpace}" 
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="13"/>
                                        </StackPanel>
                                        
                                        <!-- Disk Usage -->
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="⚙" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="Disk Usage: " 
                                                      Foreground="{DynamicResource TextSecondaryBrush}" 
                                                      FontSize="13"/>
                                            <TextBlock Text="{Binding SpaceAnalysisDiskUsage}" 
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="13"/>
                                        </StackPanel>
                                        
                                        <!-- Status -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding SpaceAnalysisStatus}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        <Setter Property="FontSize" Value="13"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SpaceAnalysisHasWarning}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Button Content="🔍 Analyze Space"
                                       Command="{Binding AnalyzeSpaceCommand}"
                                       Padding="20,10"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       HorizontalAlignment="Left"
                                       Cursor="Hand"/>
                            </StackPanel>
                        </Border>

                        <!-- Enable Date Organization -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <CheckBox Content="📅 Enable Date Organization"
                                         IsChecked="{Binding EnableDateOrganization}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         Margin="0,0,0,10"/>

                                <TextBlock Text="Organize files into date-based folders within each category" 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="13"
                                          Margin="25,0,0,10"/>
                                
                                <!-- Date Format Dropdown (visible when enabled) -->
                                <Grid Visibility="{Binding EnableDateOrganization, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="25,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" 
                                              Text="Date Format:" 
                                              VerticalAlignment="Center" 
                                              Foreground="{DynamicResource TextBrush}"/>
                                    <ComboBox Grid.Column="1" 
                                             ItemsSource="{Binding DateFormats}"
                                             SelectedItem="{Binding DateFormat}"
                                             Height="35"
                                             FontSize="14"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Error Recovery Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="🔧" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Error Recovery" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <CheckBox Content="Continue on errors (don't stop entire operation)"
                                         IsChecked="{Binding ContinueOnErrors}"
                                         FontSize="13"
                                         Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                              Text="Retry Attempts:"
                                              FontSize="13"
                                              Foreground="{DynamicResource TextBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1"
                                            Text="{Binding RetryAttempts}"
                                            Width="60"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            Margin="0,0,30,0"/>

                                    <TextBlock Grid.Column="2" 
                                              Text="Retry Delay (sec):"
                                              FontSize="13"
                                              Foreground="{DynamicResource TextBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="3"
                                            Text="{Binding RetryDelaySeconds}"
                                            Width="60"
                                            Height="30"
                                            VerticalContentAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Configuration Management -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="⚙" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Configuration Management" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <WrapPanel HorizontalAlignment="Center" Margin="0,10">
                                    <Button Content="💾 Save Configuration"
                                           Command="{Binding SaveConfigCommand}"
                                           Padding="25,12"
                                           Margin="0,0,15,0"
                                           Background="{DynamicResource SuccessBrush}"
                                           Foreground="White"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                    <Button Content="🗑 Clear Configuration"
                                           Command="{Binding ClearConfigCommand}"
                                           Padding="25,12"
                                           Background="{DynamicResource ErrorBrush}"
                                           Foreground="White"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                </WrapPanel>

                                <TextBlock Text="💡 Tip: Configuration is automatically saved on app close. Use Clear to reset all settings." 
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          FontSize="12"
                                          TextAlignment="Center"
                                          Margin="0,15,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OPERATIONS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Operations"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scan Operations -->
                    <Border Grid.Row="0" 
                           Background="{DynamicResource PanelBackgroundBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="🔍" FontSize="18" Margin="0,0,10,0"/>
                                <TextBlock Text="Scan Operations" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>

                            <WrapPanel Margin="0,10">
                                <Button Content="📊 Initial Scan" 
                                       Command="{Binding InitialScanCommand}"
                                       Padding="20,12"
                                       Margin="0,0,15,0"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                                <Button Content="⚡ Quick Scan" 
                                       Command="{Binding QuickScanCommand}"
                                       Padding="20,12"
                                       Margin="0,0,15,0"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                                <Button Content="↩ Undo Last Move" 
                                       Command="{Binding UndoCommand}"
                                       Padding="20,12"
                                       Background="{DynamicResource WarningBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- File Queue -->
                    <Border Grid.Row="1" 
                           Background="{DynamicResource PanelBackgroundBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20"
                           Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="File Queue" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="Pending: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                                    <TextBlock Text="{Binding PendingCount}" Foreground="{DynamicResource InfoBrush}" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="Moved: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                                    <TextBlock Text="{Binding MovedCount}" Foreground="{DynamicResource SuccessBrush}" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <TextBlock Text="Failed: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                                    <TextBlock Text="{Binding FailedCount}" Foreground="{DynamicResource ErrorBrush}" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1" 
                                     ItemsSource="{Binding FileQueue}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     Background="{DynamicResource WindowBackgroundBrush}"
                                     RowBackground="{DynamicResource PanelBackgroundBrush}"
                                     AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     GridLinesVisibility="Horizontal"
                                     HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="2*"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="100"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTextColumn Header="Verification" Binding="{Binding VerificationMethod}" Width="120"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding SourcePath}" Width="3*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Move Operations -->
                    <Border Grid.Row="2" 
                           Background="{DynamicResource PanelBackgroundBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="🚀" FontSize="18" Margin="0,0,10,0"/>
                                <TextBlock Text="Move Operations" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>

                            <WrapPanel Margin="0,10" HorizontalAlignment="Center">
                                <Button Content="👁 Dry Run (Preview)" 
                                       Command="{Binding DryRunCommand}"
                                       Padding="25,15"
                                       Margin="0,0,15,0"
                                       Background="{DynamicResource InfoBrush}"
                                       Foreground="White"
                                       FontSize="15"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                                <Button Content="✓ Live Move" 
                                       Command="{Binding LiveMoveCommand}"
                                       Visibility="{Binding ShowLiveMoveButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Padding="25,15"
                                       Margin="0,0,15,0"
                                       Background="{DynamicResource SuccessBrush}"
                                       Foreground="White"
                                       FontSize="15"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                                <Button Content="✓ Live Copy" 
                                       Command="{Binding LiveCopyCommand}"
                                       Visibility="{Binding ShowLiveCopyButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Padding="25,15"
                                       Margin="0,0,15,0"
                                       Background="{DynamicResource SuccessBrush}"
                                       Foreground="White"
                                       FontSize="15"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                                <Button Content="🗑 Clear Queue" 
                                       Command="{Binding ClearQueueCommand}"
                                       Padding="25,15"
                                       Background="{DynamicResource ErrorBrush}"
                                       Foreground="White"
                                       FontSize="15"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- STATISTICS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Statistics"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <!-- Overall Statistics -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="📈" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Overall Statistics" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Total Files Organized" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding TotalFilesOrganized}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource SuccessBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Total Operations" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding TotalOperations}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource InfoBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="Data Processed (GB)" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding DataProcessedGB, StringFormat={}{0:F2}}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource WarningBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Data Integrity Verification Results -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="🔒" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Data Integrity Verification" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Files Verified" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding TotalFilesVerified}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource InfoBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Verification Passed" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding VerificationPassed}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource SuccessBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="Verification Failed" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding VerificationFailed}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource ErrorBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="Success Rate" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding VerificationSuccessRate, StringFormat={}{0:F1}%}" 
                                                  TextAlignment="Center"
                                                  Foreground="{DynamicResource AccentBrush}"
                                                  FontSize="36"
                                                  FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding VerificationRetried, StringFormat={}Retried and Succeeded: {0} files}" 
                                          Foreground="{DynamicResource WarningBrush}"
                                          FontSize="14"
                                          Margin="0,20,0,0"
                                          HorizontalAlignment="Center"
                                          FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Duplicate Detection Results -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="🔁" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Duplicate Detection Results" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Duplicate Groups Found:" 
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding DuplicateGroupsFound}" 
                                                  Foreground="{DynamicResource WarningBrush}"
                                                  FontSize="28"
                                                  FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Wasted Space:" 
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  FontSize="14"
                                                  Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding WastedSpaceGB, StringFormat={}{0:F2}}" 
                                                      Foreground="{DynamicResource ErrorBrush}"
                                                      FontSize="28"
                                                      FontWeight="Bold"/>
                                            <TextBlock Text=" GB" 
                                                      Foreground="{DynamicResource ErrorBrush}"
                                                      FontSize="14"
                                                      VerticalAlignment="Bottom"
                                                      Margin="5,0,0,5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Button Content="🔄 Refresh Statistics" 
                                       Command="{Binding RefreshStatisticsCommand}"
                                       Padding="20,12"
                                       Margin="0,20,0,0"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       HorizontalAlignment="Left"
                                       Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- EXCEPTIONS TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚫" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Exceptions"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                           Background="{DynamicResource PanelBackgroundBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Exclude specific files or folders from being moved/scanned" 
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="14"
                                      TextWrapping="Wrap"
                                      Margin="0,0,0,15"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                          Text="📌 Exception Types:" 
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextBrush}"
                                          Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="• Exclude: Completely ignores matching files/folders during scan and move operations" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,2"/>
                                    <TextBlock Text="• Semi: Folder structure remains intact; only contents are duplicated to destination folder" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,2"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="ExceptionsDataGrid"
                             Grid.Row="1" 
                             ItemsSource="{Binding Exceptions}"
                             AutoGenerateColumns="False"
                             SelectionMode="Extended"
                             CanUserAddRows="False"
                             Background="{DynamicResource WindowBackgroundBrush}"
                             RowBackground="{DynamicResource PanelBackgroundBrush}"
                             AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource BorderBrush}"
                             GridLinesVisibility="Horizontal"
                             HeadersVisibility="Column"
                             Margin="0,0,0,20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*" IsReadOnly="True"/>
                            <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="models:ExceptionType">
                                                    <models:ExceptionType>Exclude</models:ExceptionType>
                                                    <models:ExceptionType>Semi</models:ExceptionType>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource">
                                            <Setter.Value>
                                                <x:Array Type="models:ExceptionType">
                                                    <models:ExceptionType>Exclude</models:ExceptionType>
                                                    <models:ExceptionType>Semi</models:ExceptionType>
                                                </x:Array>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <WrapPanel Grid.Row="2" HorizontalAlignment="Center">
                        <Button Content="➕ Add Exception" 
                               Command="{Binding AddExceptionCommand}"
                               Padding="20,12"
                               Margin="0,0,15,0"
                               Background="{DynamicResource AccentBrush}"
                               Foreground="White"
                               FontSize="14"
                               BorderThickness="0"
                               Cursor="Hand"/>
                        <Button Content="➖ Remove Selected" 
                               Click="RemoveSelectedExceptions_Click"
                               Padding="20,12"
                               Background="{DynamicResource ErrorBrush}"
                               Foreground="White"
                               FontSize="14"
                               BorderThickness="0"
                               Cursor="Hand"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- HISTORY TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="History"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                           Background="{DynamicResource PanelBackgroundBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Recent Scan Operations (Last 10)" 
                                      FontSize="18" 
                                      FontWeight="SemiBold" 
                                      Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" 
                             ItemsSource="{Binding History}"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             Background="{DynamicResource WindowBackgroundBrush}"
                             RowBackground="{DynamicResource PanelBackgroundBrush}"
                             AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource BorderBrush}"
                             GridLinesVisibility="Horizontal"
                             HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampFormatted}" Width="180"/>
                            <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="100"/>
                            <DataGridTextColumn Header="Files Scanned" Binding="{Binding FilesScanned}" Width="130"/>
                            <DataGridTextColumn Header="Success Count" Binding="{Binding SuccessCount}" Width="130"/>
                            <DataGridTextColumn Header="Verification" Binding="{Binding VerificationStatusDisplay}" Width="180"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- DUPLICATES TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔁" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Duplicates"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        
                        <!-- Detection Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="🔍" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Duplicate Detection" 
                                              FontSize="18" 
                                              FontWeight="SemiBold" 
                                              Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <RadioButton Content="⚡ Full Scan (SHA256 - Most Accurate)" 
                                                IsChecked="{Binding UseQuickScan, Converter={StaticResource InverseBooleanConverter}}"
                                                Margin="0,0,30,0"
                                                GroupName="ScanType"/>
                                    <RadioButton Content="🚀 Quick Scan (Size Only - Faster)" 
                                                IsChecked="{Binding UseQuickScan}"
                                                GroupName="ScanType"/>
                                </StackPanel>
                                
                                <Button Content="🔍 Detect Duplicates" 
                                       Command="{Binding DetectDuplicatesCommand}"
                                       Padding="15,10"
                                       HorizontalAlignment="Left"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Summary Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Duplicate Groups" 
                                              FontSize="12" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding DuplicateGroupsFound}" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Duplicate Files" 
                                              FontSize="12" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding TotalDuplicateFiles}" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource WarningBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Wasted Space" 
                                              FontSize="12" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding WastedSpaceGB, StringFormat={}{0:F2} GB}" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource ErrorBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Selected to Delete" 
                                              FontSize="12" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}">
                                        <Run Text="{Binding SelectedForDeletion, Mode=OneWay}"/>
                                        <Run Text=" files ("/>
                                        <Run Text="{Binding SelectedDeletionSpaceGB, StringFormat={}{0:F2}, Mode=OneWay}"/>
                                        <Run Text=" GB)"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Auto-Select Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="⚙️ Smart Selection" 
                                          FontSize="16" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Auto-select strategy:" 
                                              VerticalAlignment="Center" 
                                              Margin="0,0,15,0"/>
                                    <ComboBox SelectedItem="{Binding KeepStrategy}" 
                                             Width="200">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Keep Newest"/>
                                        <ComboBoxItem Content="Keep Oldest"/>
                                        <ComboBoxItem Content="Keep Shortest Path"/>
                                        <ComboBoxItem Content="Keep Longest Path"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Duplicate Groups List -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="📂 Duplicate Groups" 
                                          FontSize="16" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,0,15"/>
                                
                                <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                       BorderBrush="{DynamicResource BorderBrush}"
                                                       BorderThickness="1"
                                                       CornerRadius="5"
                                                       Padding="15"
                                                       Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <!-- Group Header -->
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                      Text="{Binding GroupDisplayName}" 
                                                                      FontWeight="SemiBold"
                                                                      FontSize="14"/>
                                                            <Button Grid.Column="1"
                                                                   Content="{Binding IsExpanded, Converter={StaticResource ExpandCollapseConverter}}"
                                                                   Command="{Binding DataContext.ToggleGroupExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Background="Transparent"
                                                                   BorderThickness="0"
                                                                   Cursor="Hand"
                                                                   Padding="5"/>
                                                        </Grid>
                                                        
                                                        <!-- Files in Group (Collapsible) -->
                                                        <ItemsControl ItemsSource="{Binding DuplicateFiles}" 
                                                                     Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                                                                           BorderBrush="{DynamicResource BorderBrush}"
                                                                           BorderThickness="1"
                                                                           CornerRadius="3"
                                                                           Padding="10"
                                                                           Margin="0,0,0,5">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            
                                                                            <CheckBox Grid.Column="0"
                                                                                     IsChecked="{Binding IsSelected}"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="0,0,10,0"/>
                                                                            
                                                                            <TextBlock Grid.Column="1"
                                                                                      Text="{Binding DisplayIcon}"
                                                                                      FontSize="16"
                                                                                      VerticalAlignment="Center"
                                                                                      Margin="0,0,10,0"/>
                                                                            
                                                                            <StackPanel Grid.Column="2">
                                                                                <TextBlock Text="{Binding DisplayPath}" 
                                                                                          FontWeight="Medium"
                                                                                          TextWrapping="NoWrap"
                                                                                          TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{Binding DisplayDates}" 
                                                                                          FontSize="11"
                                                                                          Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        
                        <!-- Actions Section -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25">
                            <StackPanel>
                                <TextBlock Text="⚡ Actions" 
                                          FontSize="16" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🗑️ Delete Selected" 
                                           Command="{Binding DeleteSelectedDuplicatesCommand}"
                                           Padding="15,10"
                                           Margin="0,0,10,0"
                                           Background="{DynamicResource ErrorBrush}"
                                           Foreground="White"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                    <Button Content="📁 Move to Folder" 
                                           Command="{Binding MoveSelectedDuplicatesCommand}"
                                           Padding="15,10"
                                           Margin="0,0,10,0"
                                           Background="{DynamicResource WarningBrush}"
                                           Foreground="White"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                    <Button Content="📄 Export List" 
                                           Command="{Binding ExportDuplicateListCommand}"
                                           Padding="15,10"
                                           Margin="0,0,10,0"
                                           Background="{DynamicResource AccentBrush}"
                                           Foreground="White"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Cursor="Hand"/>
                                    <Button Content="🔄 Clear Selection" 
                                           Command="{Binding ClearDuplicateSelectionCommand}"
                                           Padding="15,10"
                                           Background="{DynamicResource PanelBackgroundBrush}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           BorderBrush="{DynamicResource BorderBrush}"
                                           BorderThickness="1"
                                           Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- HELP TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❓" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Help"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <!-- Version Information -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="📦" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Version Information" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <TextBlock Text="Portable File Organizer" 
                                          FontSize="16" 
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextBrush}"
                                          Margin="0,10,0,5"/>
                                <TextBlock Text="v5.0 build 1.2.11" 
                                          FontSize="14" 
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="© 2026 - Professional File Management Solution" 
                                          FontSize="13" 
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,15"/>
                                
                                <!-- Test Notifications Button -->
                                <Button Content="🔔 Test Toast Notifications"
                                       Command="{Binding TestNotificationsCommand}"
                                       Padding="15,10"
                                       Background="{DynamicResource AccentBrush}"
                                       Foreground="White"
                                       FontSize="14"
                                       BorderThickness="0"
                                       Cursor="Hand"
                                       HorizontalAlignment="Left"
                                       ToolTip="Send a test notification to verify Windows toast notifications are working"/>
                            </StackPanel>
                        </Border>

                        <!-- Changelog -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" 
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="25"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Changelog" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <!-- Build 1.2.9 -->
                                <TextBlock Text="Build 1.2.9 - In-App Banner Notifications" 
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource AccentBrush}"
                                          FontSize="16"
                                          Margin="0,10,0,10"/>

                                <StackPanel Margin="15,0,0,20">
                                    <TextBlock Text="• Beautiful Banner Notifications - Replaced all popup dialogs with elegant in-app banners (similar to Timer Suite)" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,3"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="• Non-Blocking Design - Banners appear at top of window, don't interrupt workflow, auto-dismiss after 15 seconds" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,3"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="• Rich Statistics Display - Shows all operation details inline: files processed, duration, success/fail counts, space saved" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,3"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="• Manual Dismiss Button - Click '✕ Dismiss' on right side to close banner immediately when you're ready" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
                                              Margin="0,3"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="• Smooth Animations - Banners slide in from top with elegant fade effects, professional appearance" 
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              FontSize="13"
