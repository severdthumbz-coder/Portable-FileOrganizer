<UserControl x:Class="FileOrganizer.Views.SearchTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileOrganizer"
             xmlns:models="clr-namespace:FileOrganizer.Models"
             xmlns:converters="clr-namespace:FileOrganizer.Converters">

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search controls -->
        <Border Grid.Row="0"
               Background="{DynamicResource PanelBackgroundBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               BorderThickness="1"
               CornerRadius="5"
               Padding="20"
               Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="🔎" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Find Files" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
                <TextBlock Text="Search by file name, and optionally inside PDFs, Word/Excel/PowerPoint documents, and text files."
                          Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Folder:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchFolder, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseSearchFolderCommand}" Padding="12,6"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Search for:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="🔎 Search" Command="{Binding RunSearchCommand}" Padding="16,6" Margin="0,0,8,0"
                           IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBooleanConverter}}"/>
                    <Button Grid.Column="3" Content="✕ Cancel" Command="{Binding CancelSearchCommand}" Padding="12,6"
                           IsEnabled="{Binding IsSearching}"/>
                </Grid>

                <WrapPanel>
                    <CheckBox Content="Search inside file contents" IsChecked="{Binding SearchContents}" Foreground="{DynamicResource TextBrush}" Margin="0,0,20,0"/>
                    <CheckBox Content="Include subfolders" IsChecked="{Binding SearchIncludeSubfolders}" Foreground="{DynamicResource TextBrush}" Margin="0,0,20,0"/>
                    <Button Content="Clear Results" Command="{Binding ClearSearchResultsCommand}" Padding="10,4"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Results -->
        <DataGrid Grid.Row="1"
                 ItemsSource="{Binding SearchResults}"
                 AutoGenerateColumns="False"
                 IsReadOnly="True"
                 Background="{DynamicResource WindowBackgroundBrush}"
                 RowBackground="{DynamicResource PanelBackgroundBrush}"
                 AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource BorderBrush}"
                 GridLinesVisibility="Horizontal"
                 HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="2*"/>
                <DataGridTextColumn Header="Matched In" Binding="{Binding MatchedIn}" Width="100"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="90"/>
                <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedFormatted}" Width="140"/>
                <DataGridTextColumn Header="Snippet" Binding="{Binding Snippet}" Width="3*"/>
                <DataGridTextColumn Header="Folder" Binding="{Binding Directory}" Width="2*"/>
                <DataGridTemplateColumn Header="Open" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📂 Open"
                                   FontSize="11"
                                   Padding="6,3"
                                   Margin="2"
                                   Cursor="Hand"
                                   Command="{Binding DataContext.OpenSearchHitFolderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <Border Grid.Row="2"
               Background="{DynamicResource PanelBackgroundBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               BorderThickness="1"
               CornerRadius="5"
               Padding="15,10"
               Margin="0,15,0,0">
            <TextBlock Text="{Binding SearchStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
        </Border>
    </Grid>

</UserControl>
