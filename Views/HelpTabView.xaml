<UserControl x:Class="FileOrganizer.Views.HelpTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileOrganizer"
             xmlns:models="clr-namespace:FileOrganizer.Models"
             xmlns:converters="clr-namespace:FileOrganizer.Converters">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20">
            <!-- Version Information -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" 
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="25"
                   Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="📦" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Version Information" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Portable File Organizer" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource TextBrush}"
                              Margin="0,10,0,5"/>
                    <TextBlock Text="v5.0 build 1.4.7" 
                              FontSize="14" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="© 2026 - Professional File Management Solution" 
                              FontSize="13" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Margin="0,0,0,15"/>

                    <!-- Test Notifications Button -->
                    <Button Content="🔔 Test Toast Notifications"
                           Command="{Binding TestNotificationsCommand}"
                           Padding="15,10"
                           Background="{DynamicResource AccentBrush}"
                           Foreground="White"
                           FontSize="14"
                           BorderThickness="0"
                           Cursor="Hand"
                           HorizontalAlignment="Left"
                           ToolTip="Send a test notification to verify Windows toast notifications are working"/>
                </StackPanel>
            </Border>

            <!-- Quick Start Guide -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" 
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="25"
                   Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🚀" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Quick Start Guide" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="1. Configure Settings" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="14"
                                  Margin="0,10,0,5"/>
                        <TextBlock Text="   Select your scan mode, copy engine, and operation preferences in the Configuration tab." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="2. Select Folders" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Choose your source folder to scan and destination folder for organized files." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="3. Run a Scan" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Click 'Initial Scan' in the Operations tab to analyze your files. Review the queue, then execute a Dry Run or Live Move." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recommended Workflow -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" 
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="25"
                   Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🧭" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Recommended Workflow" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <TextBlock Text="A safe, repeatable process for organizing a new set of files with no surprises:" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="13"
                              Margin="0,0,0,10"
                              TextWrapping="Wrap"/>

                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="1. Set up exceptions first" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,10,0,5"/>
                        <TextBlock Text="   In the Exceptions tab, add any files, folders, or patterns you never want touched (e.g. system folders, active projects). Exceptions are applied on every scan, so setting them once protects every future run." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="2. Confirm your configuration" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Choose your copy engine and structure mode, then check the disk-space panel. If auto-detection picks the wrong drive type, set a manual override so the adaptive engine tunes its thread count correctly for your storage (NVMe / SSD / HDD)." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="3. Scan, then review the queue" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Run Initial Scan (or Quick Scan for a faster pass), then read the File Queue: check categories, sizes, and destination paths before doing anything irreversible." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="4. Always Dry Run before a Live Move" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Use Dry Run (Preview) to see exactly what would move, how much data, and how conflicts would be handled — with no files touched. When the preview matches your intent, run Live Copy or Live Move." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="5. Check for duplicates" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   In the Duplicates tab, run a Full (SHA-256) scan for accuracy or a Quick (size-only) scan for speed. Use a smart-selection strategy to auto-select which copies to remove, review the selection, then delete or move them." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="6. Verify, and undo if needed" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Check the History and Statistics tabs to confirm results. If a Move didn't go as planned, use Undo Last Move to return files to their original locations. If an operation was interrupted, relaunch and use the resume/undo prompt to recover cleanly." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="7. Watch the live performance monitor" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   During a Live Move or Copy, the Operations tab shows real-time speed, time remaining, throughput, and data transferred. Use it to confirm large transfers are running at full speed and to gauge how long a big job will take." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="8. Automate once you trust your rules" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Once a workflow is proven, recreate it as rules in the Automation tab. Test with Run Sweep Now, then enable Real-Time Watching to sort files as they arrive, or a Scheduled Sweep to tidy folders on a timer. To repeat a past job, use the Re-run button in History to reload its settings for review." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="9. Sort by what's inside, not just the name" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   For documents whose filenames aren't meaningful (scan_003.pdf), add a Content contains or Content matches regex condition. FileOrganizer reads text inside PDFs, Word, Excel, PowerPoint, and text files. Pair a content condition with a cheap one (like Extension is .pdf) so only relevant files are opened and read." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="10. Find anything afterward" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="   Use the Search tab to locate files by name, or tick 'Search inside file contents' to search the text within your documents. Results show a snippet of the matching text and an Open button to reveal the file in Explorer." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Tip: Save your configuration once it's dialed in — it's reused on every launch, so you only build this setup once." 
                                  FontStyle="Italic"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="12"
                                  Margin="0,15,0,0"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Features Overview -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" 
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="25"
                   Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="⭐" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Features Overview" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="Smart Categorization" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,10,0,5"/>
                        <TextBlock Text="Automatically categorizes files by type (Documents, Images, Videos, Audio, Archives, etc.) based on comprehensive extension mapping." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Automation: Rules, Watching &amp; Scheduling" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Define rules (by extension, name, regex, size, or date) that route files to destinations. Let FileOrganizer sort files automatically the moment they arrive (Real-Time Watching) or on a recurring timer (Scheduled Sweeps), with a live activity log." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Live Performance Monitor" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="During Live Move/Copy, watch real-time transfer speed, estimated time remaining, throughput (files/sec), and data transferred — so you can see large jobs running at full speed and know how long they'll take." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Resilient Transfers" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Retries use exponential backoff (capped) to smooth over transient failures common on network and flaky drives, complementing resume-after-interruption and copy-verify safety." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Re-run from History" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Reload a past operation's source, destination, and mode with one click from the History tab, then review and run again." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Content-Aware Sorting" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Rules can match on the text inside files, not just filenames. Reads PDFs, Word, Excel, PowerPoint, and text/code files — so a lease is filed as a lease even when it's named scan_003.pdf. Content is read lazily and cached, and cheap conditions are checked first to avoid unnecessary disk reads." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Full-Text Search" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Search your organized files by name or by the text inside them. Results show where the match came from, a snippet of surrounding text, and an Open button that reveals the file in Explorer." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Multiple Copy Engines" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Choose between Windows Standard, Custom Fast, TeraCopy, or FastCopy for optimized file transfer performance." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Flexible Structure Modes" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Organize by category, preserve original structure, or use hybrid mode to maintain folder hierarchies while categorizing." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>

                        <TextBlock Text="Safe Operation Modes" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource AccentBrush}"
                                  FontSize="14"
                                  Margin="0,15,0,5"/>
                        <TextBlock Text="Test changes with Dry Run before executing. Support for both Move and Copy operations with intelligent conflict resolution." 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Changelog -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" 
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Changelog" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <!-- Build 1.4.7 -->
                    <TextBlock Text="Build 1.4.7 - StatisticsViewModel Extracted (Refactor Step 4d, part 1)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• StatisticsViewModel - The Statistics tab now owns all its counters (files organized, operations, data processed, verification totals, success rate) instead of MainViewModel" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Statistics is a read-model - Operational code (live move/copy, duplicate detection, resume) writes totals through a single stats channel, so the counters live in one place and the pipeline never touches them directly" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• ~29 write sites consolidated - Scattered counter increments across the Operations code now route through one RecordOperation call per batch, plus simple operation counting elsewhere" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• No behavior change - All statistics display and update exactly as before, including the duplicate figures shared with the Duplicates tab" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Next: OperationsViewModel completes the refactor (the queue, undo, and resume)" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.6 -->
                    <TextBlock Text="Build 1.4.6 - DuplicatesViewModel Extracted (Refactor Step 4c)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• DuplicatesViewModel - The Duplicates tab now owns detection, the duplicate groups, keep-strategy auto-selection, and the delete/move/export actions (the largest extraction yet: ~500 lines out of MainViewModel)" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Statistics stay in sync - A new stats channel lets the Duplicates tab update the groups-found and wasted-space totals shown on the Statistics tab without owning them" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Shared UI respected - The progress bar, last-operation duration, scan mode, and history all remain shared; the Duplicates tab reports into them through narrow callbacks" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• No behavior change - Detect, auto-select, delete to Recycle Bin, move, export to CSV, and clear selection all work exactly as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.5 -->
                    <TextBlock Text="Build 1.4.5 - HistoryViewModel Extracted (Refactor Step 4b)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• HistoryViewModel - The History tab now owns its list, its on-disk persistence, and the Re-run action" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Operational code untouched - The 16 places that record history still call one forwarding method, so scans, moves, copies, undo, and resume log exactly as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Fixed a latent Re-run issue - Storage detection now refreshes whenever the source folder changes, including via Re-run, not only when set from the Configuration tab" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• No behavior change - History displays, persists, reloads, and re-runs exactly as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.4 -->
                    <TextBlock Text="Build 1.4.4 - ExceptionsViewModel Extracted (Refactor Step 4a)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• ExceptionsViewModel - The Exceptions tab now has its own ViewModel, owning the filter list and the add/remove actions" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Shared collection preserved - The scan pipeline still applies your exceptions; MainViewModel exposes the same collection instance so filtering is unchanged" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Measured before moving - Coupling analysis showed Statistics, Duplicates, History, and Operations are woven into the operational core (Statistics alone is written from 33 sites), so they are being extracted carefully rather than all at once" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• No behavior change - Exceptions add/remove, multi-select removal, and persistence all work exactly as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.3 -->
                    <TextBlock Text="Build 1.4.3 - Shared Services Extracted (Refactor Step 3)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• NotificationService - The status bar and the completion banner are now behind one service, so any feature can report to you without reaching into MainViewModel" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• SessionContext - Source folder, destination folder, operation mode, and the source-folder list now live in one shared object instead of being scattered across the God object" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Sharper boundaries - ITransferSettingsProvider now covers only how files are transferred (verification, retries, timestamps); where they come from and go is SessionContext's job" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• 92 call sites untouched - StatusMessage and ShowCompletionBanner keep working exactly as before by delegating to the new service, so no behavior changed" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Groundwork complete - With status, banner, and folder state extracted, the remaining tabs can now be split into their own ViewModels" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.2 -->
                    <TextBlock Text="Build 1.4.2 - Feature ViewModels Extracted (Refactor Step 2)" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
                              Margin="0,10,0,10"/>

                    <StackPanel Margin="15,0,0,20">
                        <TextBlock Text="• SearchViewModel and AutomationViewModel - The Search and Automation tabs now have their own ViewModels, each owning its state, commands, and services" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Decoupled via interfaces - Child ViewModels depend on IStatusSink (to write the status bar) and ITransferSettingsProvider (to honour your transfer settings), not on MainViewModel" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• MainViewModel shrank by ~500 lines - 18 commands, 16 properties, and 3 collections moved out to where they belong" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• Shared ViewModelBase - Common property-change plumbing extracted, with the same implementation as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                        <TextBlock Text="• No behavior change - The two tabs bind to their child ViewModels, so every control, command, and setting works exactly as before" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,3"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Build 1.4.1 -->
                    <TextBlock Text="Build 1.4.1 - UI Architecture: Tabs Split into Views" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource AccentBrush}"
                              FontSize="16"
